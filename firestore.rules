rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['userXP', 'userLevel']) || !resource.data.keys().hasAll(['userXP', 'userLevel']));
                   
      // Price alerts sub-collection: same owner-only isolation
      match /priceAlerts/{gameId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
