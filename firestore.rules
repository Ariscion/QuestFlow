rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || userId.matches('^tg_.*');
                   
      // Price alerts sub-collection: same owner-only isolation
      match /priceAlerts/{gameId} {
        allow read, write: if (request.auth != null && request.auth.uid == userId) || userId.matches('^tg_.*');
      }
    }
  }
}
